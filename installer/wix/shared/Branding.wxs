<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!-- Shared ARP branding metadata for both online/offline MSI packages. -->
  <Fragment>
    <Icon Id="AppIcon" SourceFile="!(bindpath.assets)\PrimeDictate.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPCOMMENTS" Value="Local Whisper dictation with global hotkey capture and live transcription updates." />
    <Property Id="ARPCONTACT" Value="clientsupport@flowdevs.io" />
    <Property Id="ARPHELPLINK" Value="https://www.flowdevs.io" />
    <Property Id="ARPURLINFOABOUT" Value="https://www.flowdevs.io" />
    <Property Id="ARPURLUPDATEINFO" Value="https://www.flowdevs.io" />
  </Fragment>
</Wix>
