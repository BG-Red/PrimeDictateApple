<Window x:Class="PrimeDictate.TranscriptionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Width="500"
        Height="400"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False">
    <Border Name="OverlayBorder"
            Padding="0"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="#333333"
            Background="#0D1117"
            MouseLeftButtonDown="OnBorderMouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,12,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe UI Emoji" Text="🎙" Foreground="#007ACC" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="PrimeDictate" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Focusable="False">
                    <!-- Pin -->
                    <ToggleButton Name="PinButton" Click="OnPinClick" ToolTip="Keep open on screen" Background="Transparent" Foreground="#888" BorderThickness="0" Padding="4" Margin="0,0,4,0" Focusable="False">
                        <TextBlock Text="📌" FontFamily="Segoe UI Emoji" FontSize="14" />
                    </ToggleButton>
                    <!-- Settings -->
                    <Button Click="OnSettingsClick" ToolTip="Settings" Background="Transparent" Foreground="#888" BorderThickness="0" Padding="4" Margin="0,0,4,0" Focusable="False">
                        <TextBlock Text="⚙" FontFamily="Segoe UI Emoji" FontSize="14" />
                    </Button>
                    <!-- Minimize -->
                    <Button Click="OnMinimizeClick" ToolTip="Minimize" Background="Transparent" Foreground="#888" BorderThickness="0" Padding="8,4" Margin="0,0,4,0" Focusable="False">
                        <TextBlock Text="—" FontFamily="Segoe UI" FontWeight="Bold" FontSize="14" />
                    </Button>
                    <!-- Close -->
                    <Button Click="OnCloseClick" ToolTip="Close" Background="Transparent" Foreground="#888" BorderThickness="0" Padding="8,4" Focusable="False">
                        <TextBlock Text="✕" FontFamily="Segoe UI" FontSize="12" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Center Content -->
            <Grid Grid.Row="1" Margin="16,8,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="120" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Visualization -->
                <Grid Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Stretch" ClipToBounds="True">
                    <!-- Left Waveform -->
                    <StackPanel Name="LeftWaveform" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,45,0" FlowDirection="RightToLeft" />
                    
                    <!-- Right Waveform -->
                    <StackPanel Name="RightWaveform" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="45,0,0,0" />
                    
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Background Glow -->
                        <Ellipse Width="250" Height="250" Opacity="0.5" IsHitTestVisible="False">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#40007ACC" Offset="0" />
                                    <GradientStop Color="#00007ACC" Offset="0.8" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Sonar Ring 2 -->
                        <Ellipse Name="Ring2" Width="80" Height="80" Stroke="#007ACC" StrokeThickness="1" Opacity="0">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Ring2Scale" CenterX="40" CenterY="40" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <!-- Sonar Ring 1 -->
                        <Ellipse Name="Ring1" Width="80" Height="80" Stroke="#007ACC" StrokeThickness="2" Opacity="0">
                            <Ellipse.RenderTransform>
                                <ScaleTransform x:Name="Ring1Scale" CenterX="40" CenterY="40" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        
                        <!-- Microphone Background -->
                        <Ellipse Width="80" Height="80" Fill="#1A1F26" Stroke="#007ACC" StrokeThickness="2" />
                        <TextBlock Text="🎙" FontFamily="Segoe UI Emoji" FontSize="34" Foreground="#007ACC" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,4" />
                    </Grid>
                </Grid>

                <!-- Transcript Card -->
                <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="16" MinHeight="100">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,10">
                            <Ellipse Name="StateDot" Width="9" Height="9" Margin="0,0,8,0" VerticalAlignment="Center" Fill="#DC3545" />
                            <TextBlock Name="HeaderText" FontSize="13" FontWeight="SemiBold" Foreground="#111827" Text="Listening" />
                        </DockPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock Name="TranscriptText" FontSize="14" LineHeight="20" TextWrapping="Wrap" Foreground="#111827" Text="Listening..." />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="3" Margin="16,0,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8,4" Background="#1A1F26">
                    <TextBlock Text="English (US)" Foreground="White" FontSize="12" />
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⏸" FontFamily="Segoe UI Emoji" Foreground="#888" FontSize="14" Margin="0,0,8,0" />
                    <TextBlock Name="TimerText" Text="00:00" Foreground="White" FontSize="14" FontFamily="Consolas" />
                </StackPanel>

                <Button Grid.Column="2" Click="OnCopyClick" Background="Transparent" Foreground="#888" BorderBrush="#444" BorderThickness="1" Padding="8,4" Focusable="False">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontFamily="Segoe UI Emoji" Margin="0,0,6,0" FontSize="12" />
                        <TextBlock Text="Copy" FontSize="12" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
